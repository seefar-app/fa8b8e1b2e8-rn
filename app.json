{
  "expo": {
    "name": "DarNA - Real Estate Algeria",
    "slug": "fa8b8e1b2e8-rn",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "darna",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#ec4899",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.darna.realestate",
      "config": {
        "googleMapsApiKey": "YOUR_GOOGLE_MAPS_API_KEY"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "DarNA needs your location to show nearby properties.",
        "NSCameraUsageDescription": "DarNA needs camera access to take property photos.",
        "NSPhotoLibraryUsageDescription": "DarNA needs photo library access to upload property images."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ec4899"
      },
      "package": "com.darna.realestate",
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_GOOGLE_MAPS_API_KEY"
        }
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "CAMERA"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow DarNA to use your location to find nearby properties."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow DarNA to access your photos to upload property images."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow DarNA to access your camera to take property photos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}